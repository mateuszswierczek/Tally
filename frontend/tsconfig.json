{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
